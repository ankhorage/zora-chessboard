{
  "name": "@ankhorage/zora-chess",
  "type": "module",
  "version": "0.1.0",
  "description": "Chess UI components for React Native and React Native Web apps built on ZORA.",
  "homepage": "https://github.com/ankhorage/zora-chess#readme",
  "bugs": {
    "url": "https://github.com/ankhorage/zora-chess/issues"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankhorage/zora-chess.git"
  },
  "keywords": [
    "react-native",
    "react-native-web",
    "chess",
    "fen",
    "expo",
    "zora",
    "ui-kit"
  ],
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "browser": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && bun x tsc -p tsconfig.json",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "docs": "paradox",
    "knip": "ankhorage-knip",
    "lint": "ankhorage-eslint . --max-warnings=0",
    "lint:fix": "ankhorage-eslint . --fix --max-warnings=0",
    "format": "ankhorage-prettier --write .",
    "format:check": "ankhorage-prettier --check .",
    "prepack": "bun run build",
    "test": "bun test src",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "chess.js": "^1.4.0"
  },
  "peerDependencies": {
    "@ankhorage/zora": ">=0.1.0",
    "react": ">=18.2.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@ankhorage/devtools": "^1.0.6",
    "@ankhorage/paradox": "^0.1.7",
    "@ankhorage/zora": "^0.4.1",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "react": "^19.1.0",
    "react-native": "^0.79.5",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.13"
}
